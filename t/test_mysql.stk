## t/test_mysql.stk — assertion tests for the stryke `MySQL` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_mysql.{dylib,so}` on
## `use MySQL`. Live tests use a unique table `stryke_mysql_test_$$` when
## $MYSQL_URL (or $MYSQL_DSN) points at a reachable server.

use MySQL

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = MySQL::version()
assert_ok $version, "MySQL::version returns truthy (cdylib loaded)"

# ── liveness probe ──────────────────────────────────────────────────
val $dsn = $ENV{MYSQL_URL} // $ENV{MYSQL_DSN}
val $alive = defined $dsn && $dsn ne "" && eval { MySQL::ping(url => $dsn) }

if ($alive) {
    val $tbl = "stryke_mysql_test_$$"
    eval { MySQL::execute("DROP TABLE IF EXISTS $tbl", url => $dsn) }

    # create table
    MySQL::execute(
        "CREATE TABLE $tbl (id INT PRIMARY KEY AUTO_INCREMENT, name VARCHAR(64), score DOUBLE)",
        url => $dsn,
    )
    assert_ok 1, "create table"

    # bulk insert with positional binds
    val $ins = MySQL::execute(
        "INSERT INTO $tbl (name, score) VALUES (?, ?), (?, ?), (?, ?)",
        url  => $dsn,
        bind => ["alice", 1.5, "bob", 2.0, "charlie", 3.25],
    )
    assert_eq $ins->{affected}, 3, "insert: affected=3"

    # select all
    val @rows = MySQL::query("SELECT * FROM $tbl ORDER BY id", url => $dsn)
    assert_eq scalar(@rows), 3, "select all: 3 rows"

    # bind in query
    val @bobs = MySQL::query("SELECT * FROM $tbl WHERE name = ?", url => $dsn, bind => ["bob"])
    assert_eq scalar(@bobs), 1, "bind query: 1 row"
    assert_eq $bobs[0]->{name}, "bob", "bind query: name=bob"

    # query_scalar
    assert_eq MySQL::query_scalar("SELECT COUNT(*) AS n FROM $tbl", url => $dsn), 3, "query_scalar count"

    # query_one
    val $one = MySQL::query_one("SELECT * FROM $tbl WHERE name = ?", url => $dsn, bind => ["alice"])
    assert_eq $one->{name}, "alice", "query_one: name=alice"

    # query_col
    val @names = MySQL::query_col("SELECT name FROM $tbl ORDER BY id", url => $dsn)
    assert_eq scalar(@names), 3, "query_col: 3 names"
    assert_eq $names[0], "alice", "query_col: first=alice"

    # schema
    val $sch = MySQL::schema($tbl, url => $dsn)
    assert_eq ref($sch->{columns}), "ARRAY", "schema: columns is array"
    assert_eq scalar(@{$sch->{columns}}), 3, "schema: 3 columns"

    # tables list contains ours
    val @tables = MySQL::tables(url => $dsn)
    val $found = grep { $_ eq $tbl } @tables
    assert_ok $found, "tables: contains $tbl"

    # insert_many
    val $im = MySQL::insert_many($tbl,
        [{ name => "dana", score => 4.0 },
         { name => "eve",  score => 5.5 }],
        url => $dsn,
    )
    assert_eq $im, 2, "insert_many: inserted=2"

    # ── upsert: insert, update-on-duplicate, no-op, explicit update ───
    val $kv = "stryke_mysql_upsert_$$"
    MySQL::execute("DROP TABLE IF EXISTS $kv", url => $dsn)
    MySQL::execute("CREATE TABLE $kv (id INT PRIMARY KEY, name VARCHAR(32), hits INT)", url => $dsn)
    # first call inserts (MySQL reports 1 affected row)
    assert_eq MySQL::upsert($kv, { id => 1, name => "a", hits => 1 }, url => $dsn), 1,
        "upsert: insert path affected=1"
    # a duplicate key updates every non-key column by default (MySQL: 2 affected)
    assert_eq MySQL::upsert($kv, { id => 1, name => "A", hits => 9 }, url => $dsn), 2,
        "upsert: duplicate update affected=2"
    val $ur = MySQL::query_one("SELECT name, hits FROM $kv WHERE id = 1", url => $dsn)
    assert_eq $ur->{name}, "A", "upsert: default update overwrote name"
    assert_eq $ur->{hits}, 9, "upsert: default update overwrote hits"
    # explicit update list touches only the named columns
    MySQL::upsert($kv, { id => 1, name => "ignored", hits => 42 },
        conflict => ["id"], update => ["hits"], url => $dsn)
    val $ur2 = MySQL::query_one("SELECT name, hits FROM $kv WHERE id = 1", url => $dsn)
    assert_eq $ur2->{name}, "A", "upsert: explicit update kept name"
    assert_eq $ur2->{hits}, 42, "upsert: explicit update bumped hits"
    # empty update list = no-op self-assignment, duplicate is ignored (0 affected)
    assert_eq MySQL::upsert($kv, { id => 1, name => "nope", hits => 0 }, update => [], url => $dsn), 0,
        "upsert: empty-update duplicate is a no-op (0 affected)"
    # RETURNING is unsupported by MySQL and must be rejected
    val $rej = !eval { MySQL::upsert($kv, { id => 2 }, returning => "id", url => $dsn); 1 }
    assert_ok $rej, "upsert: rejects RETURNING (unsupported by MySQL)"

    # ── exists: row-existence short-circuit ──────────────────────────
    assert_ok  MySQL::exists($kv, undef, url => $dsn), "exists: true when the table has rows"
    assert_ok  MySQL::exists($kv, "id = 1", url => $dsn), "exists: true for a matching WHERE"
    assert_ok !MySQL::exists($kv, "id = 999", url => $dsn), "exists: false for a non-matching WHERE"

    # ── update + delete (bound SET, interpolated WHERE) ───────────────
    val $crud = "stryke_my_crud_$$"
    MySQL::execute("DROP TABLE IF EXISTS $crud", url => $dsn)
    MySQL::execute("CREATE TABLE $crud (id INT, name VARCHAR(8), hits INT)", url => $dsn)
    MySQL::insert_many($crud,
        [{ id => 1, name => "a", hits => 1 },
         { id => 2, name => "b", hits => 2 },
         { id => 3, name => "c", hits => 3 }], url => $dsn)
    assert_eq MySQL::update($crud, { name => "B", hits => 9 }, "id = 2", url => $dsn), 1,
        "update: one matching row affected"
    val $u = MySQL::query_one("SELECT name, hits FROM $crud WHERE id = 2", url => $dsn)
    assert_eq $u->{name}, "B", "update: SET applied to name"
    assert_eq $u->{hits}, 9, "update: SET applied to hits"
    assert_eq MySQL::update($crud, { hits => 0 }, undef, url => $dsn), 3,
        "update: no WHERE touches every row"
    assert_eq MySQL::query_scalar("SELECT sum(hits) FROM $crud", url => $dsn), 0,
        "update: all hits zeroed"
    assert_eq MySQL::delete($crud, "id = 1", url => $dsn), 1, "delete: one matching row"
    assert_eq MySQL::count($crud, undef, url => $dsn), 2, "delete: count reflects removal"
    assert_eq MySQL::delete($crud, undef, url => $dsn), 2, "delete: no WHERE removes the rest"
    assert_eq MySQL::count($crud, undef, url => $dsn), 0, "delete: table now empty"
    eval { MySQL::execute("DROP TABLE $crud", url => $dsn) }

    eval { MySQL::execute("DROP TABLE $kv", url => $dsn) }

    eval { MySQL::execute("DROP TABLE $tbl", url => $dsn) }
}

# ── pure helpers (no connection — always run) ────────────────────────
# Note: `\@` escapes the at-sign so stryke doesn't array-interpolate it.
val $p = MySQL::parse_dsn("mysql://app:s3cret\@db.example.com:3307/shop?charset=utf8mb4")
assert_eq $p->{user},     "app",            "parse_dsn: user"
assert_eq $p->{password}, "s3cret",         "parse_dsn: password"
assert_eq $p->{host},     "db.example.com", "parse_dsn: host"
assert_eq $p->{port},     3307,             "parse_dsn: port"
assert_eq $p->{database}, "shop",           "parse_dsn: database"
assert_eq $p->{params}{charset}, "utf8mb4", "parse_dsn: param"

val $built = MySQL::build_dsn(user => "u", password => "p\@ss/word", host => "127.0.0.1", port => 3306, database => "app")
val $rt = MySQL::parse_dsn($built)
assert_eq $rt->{password}, "p\@ss/word", "build_dsn → parse_dsn round-trips @ and / in password"
assert_eq $rt->{database}, "app",        "build_dsn → parse_dsn database"

assert_eq MySQL::quote_ident("weird`col"), "`weird``col`",  "quote_ident uses doubled backticks"

# unquote_ident: inverse of quote_ident (strip backticks, un-double).
assert_eq MySQL::unquote_ident("`weird``col`"), "weird`col", "unquote_ident: doubled backtick decodes to one"
assert_eq MySQL::unquote_ident("`plain`"),      "plain",     "unquote_ident: plain quoted name"
assert_eq MySQL::unquote_ident(MySQL::quote_ident("has space")), "has space", "unquote_ident: round-trips quote_ident"
assert_dies fn { MySQL::unquote_ident("plain") },   "unquote_ident: rejects an unquoted name"
assert_dies fn { MySQL::unquote_ident("`a`b`") },   "unquote_ident: rejects an unpaired backtick"
assert_eq MySQL::quote_literal("O'Brien"), "'O\\'Brien'",   "quote_literal backslash-escapes (default mode)"

# quote: MySQL QUOTE() built-in — like quote_literal but undef → NULL.
assert_eq MySQL::quote("O'Brien"), "'O\\'Brien'", "quote: backslash-escapes like quote_literal"
assert_eq MySQL::quote(undef),     "NULL",        "quote: undef → unquoted NULL"
assert_eq MySQL::quote(),          "NULL",        "quote: no argument → NULL"

# escape_like: backslash-prefix the LIKE metacharacters % _ \.
assert_eq MySQL::escape_like("100%"), "100\\%",     "escape_like: percent escaped"
assert_eq MySQL::escape_like("a_b"),  "a\\_b",      "escape_like: underscore escaped"
assert_eq MySQL::escape_like("c\\d"), "c\\\\d",     "escape_like: literal backslash doubled"
assert_eq MySQL::escape_like("50%_off"), "50\\%\\_off", "escape_like: both wildcards"
assert_eq MySQL::escape_like("plain"), "plain",     "escape_like: no metacharacters → unchanged"

# unescape_like: inverse of escape_like.
assert_eq MySQL::unescape_like("100\\%"), "100%",   "unescape_like: percent decoded"
assert_eq MySQL::unescape_like("a\\_b"),  "a_b",     "unescape_like: underscore decoded"
assert_eq MySQL::unescape_like("c\\\\d"), "c\\d",   "unescape_like: doubled backslash → one"
# Round-trips escape_like for every metacharacter combination.
for val $raw (q{100%}, q{a_b}, q{c\d}, q{50%_off}, q{plain}) {
    assert_eq MySQL::unescape_like(MySQL::escape_like($raw)), $raw, "unescape_like: round-trips escape_like($raw)"
}

# like_pattern: build a LIKE pattern for the common search shapes.
assert_eq MySQL::like_pattern("foo"), "%foo%",                "like_pattern: contains by default"
assert_eq MySQL::like_pattern("foo", "starts_with"), "foo%",  "like_pattern: prefix anchor"
assert_eq MySQL::like_pattern("foo", "ends_with"), "%foo",    "like_pattern: suffix anchor"
assert_eq MySQL::like_pattern("foo", "equals"), "foo",        "like_pattern: exact (escaped, no wildcards)"
assert_eq MySQL::like_pattern("50%_off"), "%50\\%\\_off%",    "like_pattern: escapes the term's own metacharacters"
assert_dies fn { MySQL::like_pattern("x", "nope") }, "like_pattern: rejects an unknown mode"

# unquote_literal: inverse of quote_literal + full default-mode escape decoding.
assert_eq MySQL::unquote_literal("'O\\'Brien'"), "O'Brien", "unquote_literal: inverts quote_literal"
assert_eq MySQL::unquote_literal(MySQL::quote_literal("a\\b")), "a\\b", "unquote_literal: round-trips backslash"
assert_eq MySQL::unquote_literal("'a\\%b\\_c'"), "a\\%b\\_c", "unquote_literal: keeps LIKE metachar backslashes"
assert_eq MySQL::unquote_literal("'it''s'"), "it's", "unquote_literal: doubled quote → one"
assert_dies fn { MySQL::unquote_literal("no quotes") }, "unquote_literal: rejects unquoted input"

# quote_qualified_ident: each dot-separated segment backtick-quoted.
assert_eq MySQL::quote_qualified_ident("mydb.my table"), "`mydb`.`my table`", "quote_qualified_ident backticks each segment"
assert_eq MySQL::quote_qualified_ident("users"), "`users`", "quote_qualified_ident: bare identifier still backticked"
assert_dies fn { MySQL::quote_qualified_ident("mydb.") }, "quote_qualified_ident rejects empty trailing segment"

# parse_qualified_ident: inverse of quote_qualified_ident (backtick variant).
val $segs = MySQL::parse_qualified_ident("`mydb`.`my table`")
assert_eq scalar(@$segs), 2,      "parse_qualified_ident: two segments"
assert_eq $segs->[1], "my table", "parse_qualified_ident: quoted segment keeps the space"
assert_eq MySQL::parse_qualified_ident("`a.b`.`c`")->[0], "a.b", "parse_qualified_ident: dot inside backticks is literal"
assert_eq MySQL::parse_qualified_ident("`we``ird`")->[0], "we`ird", "parse_qualified_ident: doubled backtick decodes to one"
assert_eq MySQL::parse_qualified_ident(MySQL::quote_qualified_ident("mydb.my table"))->[1], "my table", "parse_qualified_ident: round-trips quote_qualified_ident"
assert_dies fn { MySQL::parse_qualified_ident("a..b") }, "parse_qualified_ident: rejects an empty segment"

# format_in_list: parenthesized quoted IN-list (MySQL value-set idiom).
assert_eq MySQL::format_in_list(["a", "b", "c"]), "('a','b','c')", "format_in_list: quotes each element"
assert_eq MySQL::format_in_list(["O'Brien"]), "('O\\'Brien')",     "format_in_list: MySQL literal escaping"
assert_eq MySQL::format_in_list([]), "(NULL)",                     "format_in_list: empty → (NULL)"

# parse_in_list: inverse of format_in_list.
val $pl = MySQL::parse_in_list("('a','b','c')")
assert_eq $pl->{count}, 3,                              "parse_in_list: element count"
assert_eq join("|", @{ $pl->{values} }), "a|b|c",       "parse_in_list: values extracted"
assert_eq join("|", @{ MySQL::parse_in_list("('a,b','c')")->{values} }), "a,b|c", "parse_in_list: comma inside quotes does not split"
assert_eq MySQL::parse_in_list("('O\\'Brien','x')")->{values}[0], "O'Brien", "parse_in_list: decodes escaped quote"
assert_ok !defined(MySQL::parse_in_list("('a',NULL,42)")->{values}[1]), "parse_in_list: unquoted NULL → undef"
assert_eq MySQL::parse_in_list("()")->{count}, 0,       "parse_in_list: empty list"
# Round-trips format_in_list.
assert_eq join("|", @{ MySQL::parse_in_list(MySQL::format_in_list(["a,b", "c'd", "x"]))->{values} }), "a,b|c'd|x", "parse_in_list: round-trips format_in_list"
assert_dies fn { MySQL::parse_in_list("a,b,c") }, "parse_in_list: rejects an unparenthesized list"

# parse_enum: extract members from a MySQL ENUM/SET column type.
val $en = MySQL::parse_enum("enum('small','medium','large')")
assert_eq $en->{kind}, "enum",                          "parse_enum: kind is enum"
assert_eq $en->{count}, 3,                              "parse_enum: member count"
assert_eq join("|", @{ $en->{values} }), "small|medium|large", "parse_enum: members extracted"
assert_eq MySQL::parse_enum("SET('a','b')")->{kind}, "set", "parse_enum: SET keyword (case-insensitive)"
assert_eq MySQL::parse_enum("enum('it''s','x')")->{values}[0], "it's", "parse_enum: doubled quote decodes to one"
assert_eq join("|", @{ MySQL::parse_enum("enum('a,b','c')")->{values} }), "a,b|c", "parse_enum: comma inside a member does not split"
assert_dies fn { MySQL::parse_enum("varchar(20)") }, "parse_enum: rejects a non-enum type"

# build_enum: inverse of parse_enum.
assert_eq MySQL::build_enum(values => ["small", "medium", "large"])->{type}, "ENUM('small','medium','large')", "build_enum: ENUM keyword + quoted members"
assert_eq MySQL::build_enum(values => ["a", "b"], kind => "set")->{type}, "SET('a','b')", "build_enum: SET keyword"
assert_eq join("|", @{ MySQL::parse_enum(MySQL::build_enum(values => ["it's", "x"])->{type})->{values} }), "it's|x", "build_enum: embedded quote round-trips through parse_enum"
assert_dies fn { MySQL::build_enum(values => []) }, "build_enum: rejects an empty member list"
assert_dies fn { MySQL::build_enum(values => ["a"], kind => "varchar") }, "build_enum: rejects a non-enum/set kind"

# enum_index: MySQL's internal 1-based ENUM index (what ORDER BY sorts on).
assert_eq MySQL::enum_index("enum('Mercury','Venus','Earth')", "Venus")->{index}, 2, "enum_index: 1-based, declaration order"
assert_eq MySQL::enum_index("enum('b','a')", "a")->{index}, 2,  "enum_index: index follows declaration, not lexical order"
assert_eq MySQL::enum_index("enum('a','b')", "")->{index}, 0,   "enum_index: empty string is the 0 error value"
assert_eq MySQL::enum_index("enum('Small','Large')", "small")->{index}, 1, "enum_index: ASCII case-insensitive"
assert_ok !defined(MySQL::enum_index("enum('a','b')", "c")->{index}), "enum_index: a non-member is undef"
assert_dies fn { MySQL::enum_index("varchar(20)", "a") }, "enum_index: rejects a non-enum type"

assert_dies fn { MySQL::parse_dsn("postgres://localhost/x") }, "parse_dsn rejects a non-mysql scheme"

test_run

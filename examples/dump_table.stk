#!/usr/bin/env stryke
# examples/dump_table.stk — stream a table to NDJSON on stdout.
#
# Run:    MYSQL_DSN='mysql://…' s examples/dump_table.stk mysql.user

use MySQL

val $tbl = $ARGV[0]
die "usage: dump_table.stk TABLE\n" unless defined $tbl

val $dsn = $ENV{MYSQL_DSN}
die "set \$MYSQL_DSN\n" unless defined $dsn

val $n = MySQL::query_stream(
    "SELECT * FROM $tbl",
    dsn      => $dsn,
    callback => fn { p to_json _ },
)
warn "dumped $n rows\n"
